@page
@model Ghita_Vlad_Proiect_Facturi.Pages.Facturi.IndexModel

@{
    ViewData["Title"] = "Facturi";
}

<h1>Facturi</h1>

<p>
<a asp-page="./Create" class="btn btn-success">Adauga factura noua</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Serie</th>
            <th>Numar</th>
            <th>Data emitere</th>
            <th>Partener</th>
            <th>Produs</th>
            <th>Cantitate</th>
            <th>Total</th>
            <th>Stare</th>
            <th>Suma platita</th>
            <th>Rest de plata</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var factura in Model.Facturi)
        {
            <tr>
                <td>@factura.Serie</td>
                <td>@factura.Numar</td>
                <td>@factura.DataEmiterii.ToShortDateString()</td>
                <td>@factura.Partener?.Nume</td>
                <td>@factura.Produs?.NumeProdus</td>
                <td>@factura.Cantitate</td>
                <td>@factura.Total.ToString("C")</td>
                <td>@factura.Stare</td>
                <td>@factura.SumaPlatita.ToString("C")</td>
                <td>@factura.RestDePlata.ToString("C")</td>
                <td>
                    <a asp-page="./Details" asp-route-id="@factura.ID" class="btn btn-sm btn-info">Detalii</a>
                    <a asp-page="./Edit" asp-route-id="@factura.ID" class="btn btn-sm btn-primary">Edit</a>
                    <a asp-page="./Delete" asp-route-id="@factura.ID" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

