@page
@model Ghita_Vlad_Proiect_Facturi.Pages.Facturi.DetailsModel

@{
    ViewData["Title"] = "Detalii factura";
}

<h1>Detalii factura</h1>

<div>
    <h4>Factura</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.Serie)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Factura.Serie)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.Numar)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Factura.Numar)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.DataEmiterii)</dt>
        <dd class="col-sm-10">@Model.Factura.DataEmiterii.ToShortDateString()</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.DataScadentei)</dt>
        <dd class="col-sm-10">@Model.Factura.DataScadentei.ToShortDateString()</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.TipFactura)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Factura.TipFactura)</dd>

        <dt class="col-sm-2">Partener</dt>
        <dd class="col-sm-10">@Model.Factura.Partener?.Nume</dd>

        <dt class="col-sm-2">Produs</dt>
        <dd class="col-sm-10">@Model.Factura.Produs?.NumeProdus</dd>

        <dt class="col-sm-2">Cantitate</dt>
        <dd class="col-sm-10">@Model.Factura.Cantitate</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.Total)</dt>
        <dd class="col-sm-10">@Model.Factura.Total.ToString("C")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.Stare)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Factura.Stare)</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.SumaPlatita)</dt>
        <dd class="col-sm-10">@Model.Factura.SumaPlatita.ToString("C")</dd>

        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Factura.RestDePlata)</dt>
        <dd class="col-sm-10">@Model.Factura.RestDePlata.ToString("C")</dd>
    </dl>
</div>

@if (Model.Factura.Plati != null && Model.Factura.Plati.Any())
{
    <div>
        <h4>Plati</h4>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Data platii</th>
                    <th>Suma</th>
                    <th>Metoda plata</th>
                    <th>Observatii</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var plata in Model.Factura.Plati)
                {
                    <tr>
                        <td>@plata.DataPlatii.ToShortDateString()</td>
                        <td>@plata.Suma.ToString("C")</td>
                        <td>@plata.MetodaPlata</td>
                        <td>@plata.Observatii</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="mt-3">
    <a asp-page="./Edit" asp-route-id="@Model.Factura.ID" class="btn btn-primary">Edit</a>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
</div>
